stdin=serial
stdout=serial
stderr=serial
bootdelay=8
loadaddr=0x60000000
recovery_addr=0x60000000
recovery_max=0x40000000
recovery_stream=1
recovery_timeout=0
recovery_backend=mmc
recovery_mmcdev=0
recovery_part_kernel=0#kernel
recovery_part_rootfs=0#rootfs
recovery_part_data=0#rootfs_data
recovery_part_uboot=0#chainloader
recovery_part_uboot_alt=
aq_fw_part=0#ETHPHYFW
recovery_uboot_max=0x400000
recovery_kernel_pad=0x2000000
phy_aneg_timeout=4000
button_cmd_0_name=reset
button_cmd_0=http_recovery
mmcdev=0
kernpart=kernel
rootpart=PARTLABEL=rootfs
bootargs=console=ttyMSM0,115200n8 rootwait root=PARTLABEL=rootfs
boot_openwrt=setenv bootargs console=ttyMSM0,115200n8 rootwait root=${rootpart}; mmc dev ${mmcdev}; part start mmc ${mmcdev} ${kernpart} kernel_start; part size mmc ${mmcdev} ${kernpart} kernel_size; mmc read ${loadaddr} ${kernel_start} ${kernel_size}; bootm ${loadaddr}
bootcmd=run boot_openwrt; echo OpenWrt boot failed, starting HTTP recovery; http_recovery
