/dts-v1/;

/* Bootloader installs ATF here */
/memreserve/ 0x80000000 0x200000;

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/leds/common.h>
#include "en7581.dtsi"

/ {
	model = "XR1710G";
	compatible = "econet,xr1710g", "econet,xr1710g-ubi",
		     "gemtek,xr1710g", "gemtek,xr1710g-ubi",
		     "econet,en7581", "airoha,an7581",
		     "airoha,en7581";
	recovery-gpios = <&en7581_pinctrl 0 GPIO_ACTIVE_LOW>;
	recovery-green-led-gpios = <&en7581_pinctrl 43 GPIO_ACTIVE_LOW>,
				   <&en7581_pinctrl 44 GPIO_ACTIVE_LOW>;
	recovery-yellow-led-gpios = <&en7581_pinctrl 33 GPIO_ACTIVE_LOW>,
				    <&en7581_pinctrl 34 GPIO_ACTIVE_LOW>;

	aliases {
		serial0 = &uart1;
		led-boot = &led_status_red;
		led-failsafe = &led_status_blue;
		led-upgrade = &led_status_blue;
		led-running = &led_status_green;
	};

	chosen {
		rootdisk = <&ubi_rootfs>;
		bootargs = "console=ttyS0,115200 earlycon ubi.block=0,fit root=/dev/fit0 rootwait";
		stdout-path = "serial0:115200n8";
		linux,usable-memory-range = <0x0 0x80200000 0x0 0x7fe00000>;
	};

	memory@80000000 {
		device_type = "memory";
		reg = <0x0 0x80000000 0x0 0x80000000>;
	};

	keys {
		compatible = "gpio-keys";

		key-restart {
			label = "reset";
			gpios = <&en7581_pinctrl 0 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
		};
	};

	leds {
		compatible = "gpio-leds";

		led_status_green: led-status-green {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_STATUS;
			gpios = <&en7581_pinctrl 17 GPIO_ACTIVE_LOW>;
		};

		led_status_blue: led-status-blue {
			color = <LED_COLOR_ID_BLUE>;
			function = LED_FUNCTION_STATUS;
			gpios = <&en7581_pinctrl 19 GPIO_ACTIVE_LOW>;
		};

		led_status_red: led-status-red {
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_STATUS;
			gpios = <&en7581_pinctrl 29 GPIO_ACTIVE_LOW>;
			default-state = "on";
		};

		led_status_white: led-status-white {
			color = <LED_COLOR_ID_WHITE>;
			function = LED_FUNCTION_STATUS;
			gpios = <&en7581_pinctrl 20 GPIO_ACTIVE_LOW>;
		};

		led_lan1_green: led-lan1-green {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <1>;
			gpios = <&en7581_pinctrl 43 GPIO_ACTIVE_LOW>;
		};

		led_lan1_yellow: led-lan1-yellow {
			color = <LED_COLOR_ID_YELLOW>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <1>;
			gpios = <&en7581_pinctrl 33 GPIO_ACTIVE_LOW>;
		};

		led_lan2_green: led-lan2-green {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <2>;
			gpios = <&en7581_pinctrl 44 GPIO_ACTIVE_LOW>;
		};

		led_lan2_yellow: led-lan2-yellow {
			color = <LED_COLOR_ID_YELLOW>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <2>;
			gpios = <&en7581_pinctrl 34 GPIO_ACTIVE_LOW>;
		};
	};
};

&en7581_pinctrl {
	gpio-ranges = <&en7581_pinctrl 0 13 47>;

	mdio_pins: mdio-pins {
		mux {
			function = "mdio";
			groups = "mdio";
		};

		conf {
			pins = "gpio2";
			output-high;
		};
	};

	pcie0_rst_pins: pcie0-rst-pins {
		conf {
			pins = "pcie_reset0";
			drive-open-drain = <1>;
		};
	};

	pcie1_rst_pins: pcie1-rst-pins {
		conf {
			pins = "pcie_reset1";
			drive-open-drain = <1>;
		};
	};
};

&spi_nand {
	#address-cells = <1>;
	#size-cells = <1>;

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		partition@0 {
			label = "vendor";
			reg = <0x00000000 0x00600000>;
			read-only;
		};

		partition@600000 {
			label = "chainloader";
			reg = <0x00600000 0x00100000>;
			read-only;
		};

				partition@700000 {
					label = "ubi";
					reg = <0x00700000 0x1d9c0000>;
					compatible = "linux,ubi";

				volumes {
					ubi-volume-ubootenv {
						volname = "ubootenv";

					nvmem-layout {
						compatible = "u-boot,env-redundant-bool";
					};
				};

					ubi-volume-ubootenv2 {
						volname = "ubootenv2";

						nvmem-layout {
							compatible = "u-boot,env-redundant-bool";
						};
					};

					ubi-volume-uboot {
						volname = "uboot";
					};

					ubi_rootfs: ubi-volume-fit {
						volname = "fit";
					};

					ubi_factory: ubi-volume-factory {
						volname = "factory";
					};
				};
			};

				/*
				 * Reserve the final 250 eraseblocks for the stock
				 * bootloader's BMT/BBT handling on the 512 MiB
				 * SPI-NAND.
				 */
				reserved_bmt@1e0c0000 {
					label = "reserved_bmt";
					reg = <0x1e0c0000 0x01f40000>;
					read-only;
				};
		};
	};

&ubi_factory {
	nvmem-layout {
		compatible = "fixed-layout";
		#address-cells = <1>;
		#size-cells = <1>;

		eeprom: eeprom@0 {
			reg = <0x0 0x1e00>;
		};

		wan_mac: macaddr@5000 {
			reg = <0x5000 0x6>;
		};

		lan_mac: macaddr@6000 {
			compatible = "mac-base";
			reg = <0x6000 0x6>;
			#nvmem-cell-cells = <1>;
		};
	};
};

&i2c0 {
	status = "okay";
};

&pcie0 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&pcie0_rst_pins>;
};

&pcie1 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&pcie1_rst_pins>;
};

&eth {
	status = "okay";
};

&gdm1 {
	status = "okay";
};
